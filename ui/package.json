{
  "name": "@penumbra/ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "dev": "vite",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
